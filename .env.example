# Receipt System - Backend Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# Application
# ============================================
APP_NAME=receipt-system
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ============================================
# Database
# ============================================
# SQLite with aiosqlite for async support
# Format: sqlite+aiosqlite:///./data/receipts.db
DATABASE_URL=sqlite+aiosqlite:///./data/receipts.db
DATABASE_ECHO=false

# ============================================
# OpenRouter API (for AI analysis)
# ============================================
# Get your API key from https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_TIMEOUT=60
OPENROUTER_MAX_RETRIES=3

# ============================================
# File System Directories
# ============================================
# Directories for receipt images at different processing stages
UNPARSED_DIR=./data/unparsed
UNAPPROVED_DIR=./data/unapproved
FAILED_DIR=./data/failed
APPROVED_DIR=./data/approved

# ============================================
# Logging
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Log format: json or text
LOG_FORMAT=json

# ============================================
# File Watching (watchdog)
# ============================================
WATCHDOG_POLL_INTERVAL=1.0
WATCHDOG_RECURSIVE=false

# ============================================
# OCR (Tesseract)
# ============================================
OCR_LANGUAGE=jpn+eng
OCR_DPI=300

# ============================================
# Duplicate Detection
# ============================================
# Overall duplicate threshold (0.0-1.0)
DUPLICATE_THRESHOLD=0.85
# Image hash similarity threshold (0.0-1.0)
DUPLICATE_IMAGE_HASH_THRESHOLD=0.95
# OCR text similarity threshold (0.0-1.0)
DUPLICATE_OCR_SIMILARITY_THRESHOLD=0.90

# ============================================
# File Processing
# ============================================
# Supported image extensions (comma-separated)
SUPPORTED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp,.tiff,.bmp
# Maximum file size in MB
MAX_FILE_SIZE_MB=50

# ============================================
# Pagination
# ============================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100